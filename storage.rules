rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /campaigns/{campaignId}/{allPaths=**} {
      // Allow read/write if authenticated
      // In a production app, we'd verify campaign ownership via Firestore
      // but for this challenge, authenticated access is a good baseline.
      allow read, write: if request.auth != null;
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
