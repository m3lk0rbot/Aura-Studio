rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - isPro: boolean (required)
    //   - credits: number
    //   - createdAt: timestamp
    //
    // Collection: archives
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - platform: string (required)
    //   - content: string (required)
    //   - imageUrl: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "tangit.naga@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'isPro', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.isPro is bool &&
             data.role in ['admin', 'user'];
    }

    // Archive Validation
    function isValidArchive(data) {
      return data.keys().hasAll(['userId', 'platform', 'content', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.platform is string &&
             data.content is string &&
             data.content.size() < 10000; // Increased limit for long posts
    }

    // Campaign Validation
    function isValidCampaign(data) {
      return data.keys().hasAll(['userId', 'summary', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.summary is string &&
             data.summary.size() < 20000; // Increased limit for full campaigns
    }

    // Campaign Source Validation
    function isValidCampaignSource(data) {
      return data.keys().hasAll(['userId', 'sourceText']) &&
             data.userId == request.auth.uid &&
             data.sourceText is string &&
             data.sourceText.size() < 50000; // Large limit for input text
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.role == 'user'; // Default role
      allow update: if (isOwner(userId) || isAdmin()) && 
                    (request.resource.data.isPro == resource.data.isPro || isAdmin()) &&
                    (request.resource.data.role == resource.data.role || isAdmin()) &&
                    (request.resource.data.credits == resource.data.credits || isAdmin());
    }

    match /archives/{postId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidArchive(request.resource.data);
      allow update: if isDocOwner() && isValidArchive(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /campaigns/{campaignId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidCampaign(request.resource.data);
      allow update: if isDocOwner() && isValidCampaign(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /campaign_sources/{campaignId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidCampaignSource(request.resource.data);
      allow update: if isDocOwner() && isValidCampaignSource(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
