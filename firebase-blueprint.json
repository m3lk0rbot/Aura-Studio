{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings, subscription status, and usage metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isPro": { "type": "boolean", "description": "Whether the user has a Pro subscription" },
        "credits": { "type": "integer", "description": "Remaining generation credits" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "isPro"]
    },
    "ArchivedPost": {
      "title": "Archived Post",
      "description": "A social media post saved by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "UID of the owner" },
        "platform": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Optional generated image URL" },
        "visualDescription": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "platform", "content", "createdAt"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A full social media campaign generated by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "summary": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "images": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "description": { "type": "string" }
            }
          } 
        },
        "posts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "platform": { "type": "string" },
              "style": { "type": "string" },
              "content": { "type": "string" },
              "audioUrl": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "summary", "createdAt"]
    },
    "CampaignSource": {
      "title": "Campaign Source",
      "description": "The original source text used to generate a campaign.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sourceText": { "type": "string" }
      },
      "required": ["userId", "sourceText"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/archives/{postId}": {
      "schema": "ArchivedPost",
      "description": "Collection of posts archived by users"
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Collection of full campaigns generated by users"
    },
    "/campaign_sources/{campaignId}": {
      "schema": "CampaignSource",
      "description": "Original source text for campaigns"
    }
  }
}
